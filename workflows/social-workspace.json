    "Download Rendered MP4":{"main":[[{"node":"Upload Pending MP4 to R2","type":"main","index":0}]]},
    "Upload Pending MP4 to R2":{"main":[[{"node":"Wait Until Scheduled Time","type":"main","index":0}]]},
    "Wait Until Scheduled Time":{"main":[[{"node":"Prepare Draft Backend Request","type":"main","index":0}]]},
    "Prepare Draft Backend Request":{"main":[[{"node":"Create TikTok Draft via Backend","type":"main","index":0}]]},
    "Create TikTok Draft via Backend":{"main":[[{"node":"Classify Draft Result","type":"main","index":0}]]}
  }
}
